# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_PRIVATE_ONLY=true

# LLM providers
DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
PROVIDER_TIMEOUT_MS=45000

# Agent runtime
MAX_ITERATIONS=8
MEMORY_WINDOW_SIZE=20
MAX_QUEUE_SIZE=100
LOG_LEVEL=info

# Paths
DB_PATH=./data/oliviaclaw.db
SKILLS_DIR=./.agents/skills
TMP_DIR=./tmp
ALLOWED_TOOL_ROOTS=./src,./docs,./reports

# Feature flags
ENABLE_GITHUB_PUSH=false
ENABLE_CODE_ANALYZER=true

# Media / commands
WHISPER_COMMAND=whisper
EDGE_TTS_COMMAND=edge-tts
INPUT_DOWNLOAD_TIMEOUT_MS=30000
WHISPER_TIMEOUT_MS=120000
MAX_AUDIO_MB=20
MAX_AUDIO_DURATION_SECONDS=600
MAX_TTS_CHARS=3000

# Web tool (buscar_web)
WEB_ALLOWED_DOMAINS=duckduckgo.com,wikipedia.org,developer.mozilla.org,openai.com,github.com
WEB_TIMEOUT_MS=12000
